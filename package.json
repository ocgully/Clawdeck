{
  "name": "claudedeck",
  "version": "0.2.0",
  "description": "Standalone takeover app that turns an Elgato Stream Deck into live mission-control for your Claude Code sessions — color-coded status dashboard, virtual pages, scriptable monitor loops, one-press jump-to-session. Replaces the Elgato desktop app; talks to the deck directly over USB.",
  "type": "module",
  "bin": {
    "claudedeck": "dist/claudedeck.mjs"
  },
  "files": [
    "dist/",
    "hooks/",
    "monitors/"
  ],
  "license": "MIT",
  "author": "Christopher Gulliver",
  "keywords": [
    "stream-deck",
    "elgato",
    "claude",
    "claude-code",
    "dashboard",
    "iterm",
    "developer-tools"
  ],
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "start": "node dist/claudedeck.mjs",
    "dev": "rollup -c && node dist/claudedeck.mjs",
    "test": "rollup -c rollup.smoke.mjs && node .smoke/smoke.mjs",
    "pol": "rollup -c rollup.pol.mjs && node .pol/pol.mjs",
    "install-hooks": "node ./hooks/install.mjs"
  },
  "dependencies": {
    "@elgato-stream-deck/node": "^7.6.3",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^20.16.0",
    "rollup": "^4.24.0",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0"
  }
}
